# Copy to .env for manual setup, or let scripts/setup-local.sh create .env.
# .env is ignored by Git. Do not commit real secrets.
DB_URL=jdbc:postgresql://localhost:5432/secure_directory
DB_USERNAME=secure_directory_app
DB_PASSWORD=replace_with_a_random_database_password
SSL_KEYSTORE_PATH=file:/absolute/path/to/certs/secure-directory.p12
SSL_KEYSTORE_PASSWORD=replace_with_a_random_keystore_password
SSL_KEY_ALIAS=secure-directory
HTTPS_PORT=8443
HTTP_PORT=8080
